<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HairdresserAppointmentClient</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HairdresserAppointmentClient.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display&family=Poppins&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>
    @{
        var role = Context.Session.GetString("role");
    }

    <a href="#" id="scrollBtn" class="bi bi-caret-up-fill btn position-fixed text-bg-black d-none"></a>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-black fixed-top">
            <div class="container-fluid d-flex ">

                <a class="navbar-brand ms-5" href="#">
                    <img src="~/images/dagenslyxlogga.png" height="60">
                </a>

                <button class="navbar-toggler " type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse justify-content-end me-5" id="navbarNav">
                    <ul class="navbar-nav">

                        <li class="nav-item">
                            <a class="nav-link text-gold fw-bold" href="#">HEM</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-gold" href="#about">OM OSS</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-gold" href="#contact">HITTA HIT</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-gold" asp-page="/Booking">Bokningar</a>
                        </li>

                        @if (role == "Admin")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-gold fw-bold" href="#" data-bs-toggle="dropdown">
                                    Admin
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end bg-dark">
                                    <li><a class="dropdown-item text-gold" asp-page="/Hairdresser">Skapa Frisör</a></li>
                                    <li><a class="dropdown-item text-gold" asp-page="/Hairdresser">Göra nåt</a></li>
                                    <li>
                                        <a class="dropdown-item text-gold" asp-page="/Logout">
                                            <i class="bi bi-box-arrow-right"></i> Logga ut
                                        </a>
                                    </li>
                                </ul>
                            </li>
                        }
                        else if (role == "Hairdresser")
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-gold fw-bold" href="#" data-bs-toggle="dropdown">
                                    Frisör
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end bg-dark">
                                    <li><a class="dropdown-item text-gold" asp-page="/Hairdresser">Arbetstid</a></li>
                                    <li><a class="dropdown-item text-gold" asp-page="/Hairdresser">Ledighet</a></li>
                                </ul>
                            </li>
                        }

                    </ul>
                </div>

            </div>
        </nav>
    </header>
    <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer bg-black text-white py-2 position-fixed">
        <div class="container-fluid d-flex align-items-center small">
            <div>&copy; 2026 DagensLyx</div>
            <div class="ms-4 text-start">
                <a class="text-gold text-decoration-none me-3 fw-bolder" href="#contact">Kontakt</a>
                <a class="text-gold text-decoration-none me-3 fw-bold" href="#about">OM OSS</a>
            </div>
                @if (string.IsNullOrEmpty(role))
                {
				    <a asp-page="/login" class="text-white text-decoration-none ms-auto fs-5">
                    <i class="bi bi-box-arrow-in-right"></i>
				    </a>
                }
                
                

        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

