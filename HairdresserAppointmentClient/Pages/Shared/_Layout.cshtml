<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HairdresserAppointmentClient</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/HairdresserAppointmentClient.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg m-0 p-0 navbar-dark bg-black position-relative">
            <div class="container-fluid">

                <a class="me-0 m-0 p-0" href="/index">
                    <img src="~/images/dagenslyxsvart.png" width="250">
                    </a>

                    <div class="position-absolute top-50 start-50 translate-middle">
                        <span class="text-white  display-1 text-body" style="letter-spacing: 2px;">Dagens Lyx</span>
                    </div>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse" id="navbarNav">
                        <ul class="navbar-nav ms-auto">
                            <li class="nav-item">
                                <a class="nav-link fw-bold" asp-page="/Index">Hem</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" asp-page="/Booking">Bokningar</a>
							</li>
                            <li class="nav-item">
                                <a class="nav-link" asp-page="/Hairdresser">GömSen</a>
                            </li>
                            
                        </ul>
                    </div>

                </div>
            </nav>
    </header>
    <div class="container-fluid p-0">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - HairdresserAppointmentClient - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
