@page
@model HairdresserAppointmentClient.Pages.TreatmentsModel
@{
}
<div class="container">
	<div class="col-md-4">
		<div class="card shadow-lg border-0 rounded-4">
			<div class="card-header bg-dark text-white rounded-top-4">
				<h4 class="mb-0 fw-bold">Hairdresser registration</h4>
			</div>
            <div class="card-body">

            

                <div id="hairdresser-list">
                    <table class="table table-hover table-bordered">
                        <thead>
                            <tr>
                                <th>Id</th>
                                <th>Treatment</th>
                                <th>Duration</th>
                                <th>Price</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in Model.Treatments)
                            {
                                <tr>
                                    <td>@t.Id</td>
                                    <td>@t.Name</td>
                                    <td>@t.DurationMinutes</td>
                                    <td>@t.Price</td>
                                </tr>
                            }
                       
                        </tbody>
                    </table>
                </div>
            </div>
		</div>
	</div>
</div>
