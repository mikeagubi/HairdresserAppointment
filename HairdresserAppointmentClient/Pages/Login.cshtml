@page
@model HairdresserAppointmentClient.Pages.LoginModel
@{
}


<h2>Login</h2>
@if(Model.Role == "Admin")
{
	<div class="alert alert-success">
		<h2>inloggad som: @Model.Role</h2>
	</div>
}

<form method="post">
	<div>
		<label>Hotmail</label>
		<input asp-for="@Model.loginDto.Email" />
	</div>
	<div>
		<label>Password</label>
		<input asp-for="@Model.loginDto.Password" type="password" />
	</div>
	<button type="submit">Login</button>
</form>
<div>
	@if(Model.ErrorMessage != null)
	{
		<div class="alert alert-danger">
			@Model.ErrorMessage 
		</div>
	}
</div>


