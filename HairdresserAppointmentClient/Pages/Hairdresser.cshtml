@page
@model HairdresserAppointmentClient.Pages.HairdresserModel
@{
}
<link href="~/css/hairdresser.css" rel="stylesheet" />
<body class="bg-warning-subtle">

    <div class="container mt-4">

        <div class="row">
            @* 6kolumner, fundera på design sen!!!! *@
            <div class="col-md-6">
                <div class="card shadow-lg w-100 h-100">
                    <div class="card-body">

                        <h5 class="mb-3 fw-bold">Hairdresser registration</h5>

                        <form method="post">

                            <div class="mb-3">
                                <label asp-for="Hairdresser.Name" class="form-label fw-bold"></label>
                                <input asp-for="Hairdresser.Name" class="form-control" />
                            </div>

                            <h5 class="mt-4 mb-4 fw-bold">Schedule</h5>

                            @for (int i = 0; i < Model.Hairdresser.WorkingHours.Count; i++)
                            {
                                <div class="row mb-2">

                                    <div class="col-4 form-check">
                                        <input type="checkbox" asp-for="Hairdresser.WorkingHours[i].Selected" class="form-check-input border border-dark ms-1" />
                                        <label class="form-check-label ms-2">
                                            @Model.Hairdresser.WorkingHours[i].DayOfWeek
                                        </label>
                                    </div>

                                    <div class="col-4">
                                        <input type="time" class="form-control" value="09:00" asp-for="Hairdresser.WorkingHours[i].StartTime" />
                                    </div>

                                    <div class="col-4">
                                        <input type="time" class="form-control" value="19:00" asp-for="Hairdresser.WorkingHours[i].EndTime" />
                                    </div>

                                    <input type="hidden" asp-for="Hairdresser.WorkingHours[i].DayOfWeek" />
                                </div>
                            }

                            <div class="form-check form-switch mb-3 ms-3 ">
                                <input type="checkbox" asp-for="Hairdresser.IsActive" class="form-check-input" id="statusCheckBox" onclick="updateStatus()" />
                                <label id="statusText" class="fw-bold">
                                    Inactive
                                </label>
                            </div>

                            <button type="submit" class="btn btn-dark w-100">
                                Save
                            </button>

                        </form>

                    </div>
                </div>

            </div>

            @* 6kolumner *@
			<div class="col-md-6">
				<div class="card shadow-lg w-100 h-100">
					<div class="card-body">
						<h5 class="mb-3 fw-bold">Account registration</h5>
						<form method="post" asp-page-handler="CreateUser">
                            <input asp-for="User.Email" placeholder="Enter email..." />
                            <input asp-for="User.Password" placeholder="Enter Pass..." />
                            <select asp-for="User.HairdresserId">
                                @foreach(var dresser in Model.Hairdressers)
                                {
                                    <option value="@dresser.Id">
                                        @dresser.Name
                                    </option>                 
                                }
                            </select>
                            <button type="submit">Create</button>
						</form>
					</div>
				</div>

			</div>
        </div>
    </div>
    

</body>

<div class="col-md-6">
    <div class="card shadow-lg w-100 h-100">
        <div class="card-body">

            <h5 class="mb-3 fw-bold">Hairdressers</h5>

            <div id="hairdresser-list">
                <table class="table table-hover table-bordered">
                    <thead>
                        <tr>
                            <th>Id</th>
                            <th>Name</th>
                            <th>Active</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var h in Model.Hairdressers)
                        {
                            <tr>
                                <td>@h.Id</td>
                                <td>@h.Name</td>
                                <td>@(h.IsActive ? "Yes" : "No")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>